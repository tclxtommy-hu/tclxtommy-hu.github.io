{
  "name": "mcp-weather-server",
  "version": "1.0.0",
  "description": "MCP Weather Server - 天气查询、预报工具",
  "type": "module",
  "main": "./dist/stdio.mjs",
  "types": "./dist/stdio.d.ts",
  "bin": {
    "mcp-weather-server": "./dist/stdio.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node --input-type=module -e \"import{rmSync}from'node:fs';rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run prebuild && tsc",
    "postbuild": "node scripts/postbuild.mjs",
    "prepublishOnly": "npm run build",
    "dev": "npx tsx src/stdio.ts",
    "dev:http": "npx tsx src/http.ts",
    "start": "node dist/stdio.mjs",
    "start:http": "node dist/http.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["mcp", "model-context-protocol", "weather"],
  "license": "MIT"
}
