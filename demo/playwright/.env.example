# 默认截图目标 URL（可被命令行 --url 覆盖）
SCREENSHOT_URL=https://example.com

# 默认输出目录
SCREENSHOT_OUTPUT=screenshots

# 默认视口宽高
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800

# 是否全页截图（true/false）
FULL_PAGE=false

# 等待策略：load | domcontentloaded | networkidle | commit
WAIT_UNTIL=networkidle

# 超时时间（毫秒）
TIMEOUT=30000

# 自定义 User-Agent（留空则不设置）
USER_AGENT=

# 自定义 Cookies：
#   - JSON 数组：[{"name":"x","value":"y","domain":".example.com","path":"/"}]
#   - 简单格式：name1=value1; name2=value2（domain 自动取目标 URL 主机名）
# 留空则不设置
COOKIES=
