# DeepSeek API Key（在 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=你的_api_key_here --- IGNORE ---

# DeepSeek API 地址
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 模型名称
DEEPSEEK_MODEL=deepseek-chat

# 是否启用「会话级技能缓存」（粘性路由）
# true       = 锁定首轮选中的技能，直到 /clear 或 /skill 手动切换（原默认行为）
# false/未设置 = 每轮都让 LLM 重新路由（随话题切换技能，避免武断锁定）
SKILL_SESSION_CACHE=false
